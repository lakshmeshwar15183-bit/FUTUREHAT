# ── FUTUREHAT environment template ──────────────────────────────────────────
# Copy the relevant values into web/.env.local and mobile/.env
# The "anon"/"publishable" key is safe to expose in client apps.

# Supabase project
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx

# Web (Vite) — set these in web/.env.local
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# Production site URL — used as the target for password-reset emails, magic
# links, and any other auth callback. Must match the "Site URL" (or one of the
# entries in "Additional redirect URLs") configured in Supabase Auth → URL
# Configuration. Leave unset in dev; the code falls back to window.location.origin.
# VITE_SITE_URL=https://futurehat.app
# Optional: FUTUREHAT+ live billing via Razorpay. Leave unset for instant activation.
# VITE_RAZORPAY_KEY_ID=rzp_live_xxx

# Mobile (Expo) — set these in mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Optional: HTTPS site URL used as a fallback redirect target when the user
# opens a password-reset link on a device that can't handle the `futurehat://`
# scheme (e.g. a browser on a machine without the app installed). If set, the
# URL must ALSO appear in Supabase Auth → URL Configuration → additional
# redirect URLs. Leave unset to use the app scheme only.
# EXPO_PUBLIC_SITE_URL=https://futurehat.app

# ── Supabase Auth redirect allowlist (dashboard-side, NOT env) ──────────────
# The values below are NOT read by the code — they must be pasted into
# Supabase → Authentication → URL Configuration so the reset-password email
# link redirects your users back to your app. Missing entries silently fall
# back to the project's SITE_URL, which is the usual root cause of "the
# reset link doesn't open the app / opens the wrong page".
#   Site URL:                 https://futurehat.app
#   Additional redirect URLs: https://futurehat.app/reset-password
#                             futurehat://reset-password
#                             exp://*/*             (Expo Go dev — optional)

# ── Calls / WebRTC TURN (RECOMMENDED for production) ────────────────────────
# 1:1 calls work out of the box via Google STUN + a free public TURN relay
# (openrelay.metered.ca) baked into buildIceServers(). That free relay is
# best-effort and rate-limited — fine for testing, NOT for production scale.
# For reliable cross-network (cellular ↔ wifi, symmetric-NAT) calls, provision
# your own TURN (managed: metered.ca / Twilio / Cloudflare; self-host: coturn)
# and set the vars below. When set, your TURN is tried FIRST, defaults remain
# as fallback. Leave unset to keep the free relay.
#   Web (web/.env.local):
# VITE_TURN_URL=turn:turn.YOUR-DOMAIN.com:443?transport=tcp
# VITE_TURN_USERNAME=YOUR-TURN-USER
# VITE_TURN_CREDENTIAL=YOUR-TURN-SECRET
#   Mobile (mobile/.env):
# EXPO_PUBLIC_TURN_URL=turn:turn.YOUR-DOMAIN.com:443?transport=tcp
# EXPO_PUBLIC_TURN_USERNAME=YOUR-TURN-USER
# EXPO_PUBLIC_TURN_CREDENTIAL=YOUR-TURN-SECRET

# ── Server-only secrets (NEVER ship to clients) ─────────────────────────────
# Needed only for admin scripts / pushing migrations from this machine.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# ── Push notifications (killed-state delivery via FCM v1) ───────────────────
# The `push` Edge Function delivers real notifications to a recipient's device even
# when their app is closed/killed. It needs a Firebase service-account key (the ONLY
# real secret — set it via `supabase secrets set`, never ship it to clients):
#   supabase secrets set FCM_SERVICE_ACCOUNT="$(cat service-account.json)"
# Client side: drop `google-services.json` (Android) / `GoogleService-Info.plist`
# (iOS) into the `mobile/` folder — mobile/app.config.js wires them in automatically.
# See WORK_LOG.md → "Remaining manual setup" for the full step-by-step.

# ── Edge function secrets (set via `supabase secrets set`, never in client) ──
# Powers FUTUREHAT+ AI features (rewrite / translate / summarize / smart reply).
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional: use an Anthropic-compatible proxy instead of api.anthropic.com
# ANTHROPIC_BASE_URL=https://cc.freemodel.dev
# Optional: override the model id
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
