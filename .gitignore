# dependencies
node_modules/
**/node_modules/

# env / secrets
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# builds
dist/
build/
web/dist/
.expo/
*.tsbuildinfo

# Firebase service-account PRIVATE KEY — NEVER commit. Set as the `push` Edge
# Function secret instead: supabase secrets set FCM_SERVICE_ACCOUNT="$(cat …)"
# (google-services.json / GoogleService-Info.plist are public client config and may
# be committed; the service-account key below is the only real secret.)
**/service-account*.json
**/*firebase-adminsdk*.json

# native (regenerated by `expo prebuild`)
mobile/android/
mobile/ios/
# release artifacts + signing material — back these up OUTSIDE git
mobile/*.apk
mobile/*.aab
*.keystore
*.jks

# logs
*.log
npm-debug.log*

# os / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# test
coverage/

# Local Netlify folder
.netlify

# Local release artifacts (APK/AAB) — do not commit binaries
release/

# Validation run logs
validation/results/
