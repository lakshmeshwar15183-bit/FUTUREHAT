{
  "expo": {
    "name": "FUTUREHAT",
    "slug": "futurehat",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "futurehat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0B141A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.lakshmeshwar.futurehat"
    },
    "android": {
      "package": "dev.lakshmeshwar.futurehat",
      "adaptiveIcon": {
        "backgroundColor": "#0B141A"
      }
    },
    "extra": {
      "developer": "LAKSHMESHWAR PANDEY"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
