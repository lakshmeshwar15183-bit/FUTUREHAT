# FUTUREHAT mobile — copy to `.env` and fill in. Expo inlines EXPO_PUBLIC_* at
# build time. These point at the SAME Supabase backend as the web app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Calls / WebRTC TURN — OPTIONAL but RECOMMENDED for production.
# Calls work out of the box via Google STUN + a free public TURN relay baked in;
# that relay is best-effort/rate-limited (fine for testing, not production).
# For reliable cross-network calls, provision your own TURN (coturn / metered.ca /
# Twilio) and set these — when present, yours is tried first, defaults stay as
# fallback. Leave unset to keep the free relay.
# EXPO_PUBLIC_TURN_URL=turn:turn.YOUR-DOMAIN.com:443?transport=tcp
# EXPO_PUBLIC_TURN_USERNAME=YOUR-TURN-USER
# EXPO_PUBLIC_TURN_CREDENTIAL=YOUR-TURN-SECRET
