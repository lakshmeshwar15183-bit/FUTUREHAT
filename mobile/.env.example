# FUTUREHAT mobile — copy to `.env` and fill in. Expo inlines EXPO_PUBLIC_* at
# build time. These point at the SAME Supabase backend as the web app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Calls / WebRTC TURN — REQUIRED for production cross-network calling.
# Without TURN the app uses STUN only: calls connect on the same/permissive
# network but HANG on "Connecting…" across different networks/carriers/NATs.
# (There is no baked-in relay fallback — the old free one is dead.)
#
# Provision a TURN server (metered.ca has a free tier, or coturn / Twilio) and set
# the three vars below. EXPO_PUBLIC_TURN_URL accepts a COMMA-SEPARATED list so you
# can include every transport your provider gives you (udp/tcp/tls on 80/443)
# under the one username/credential — include a :443?transport=tcp or turns: entry
# so calls survive restrictive firewalls.
# EXPO_PUBLIC_TURN_URL=turn:turn.YOUR-DOMAIN.com:80,turn:turn.YOUR-DOMAIN.com:443?transport=tcp,turns:turn.YOUR-DOMAIN.com:443
# EXPO_PUBLIC_TURN_USERNAME=YOUR-TURN-USER
# EXPO_PUBLIC_TURN_CREDENTIAL=YOUR-TURN-SECRET
