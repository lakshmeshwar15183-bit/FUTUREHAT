{
  "name": "@futurehat/mobile",
  "version": "4.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:release": "cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@17 ./gradlew clean :app:bundleRelease :app:assembleRelease --no-daemon"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^9.0.0",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@shopify/react-native-skia": "^1.5.0",
    "@supabase/supabase-js": "^2.108.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^52.0.49",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-media-library": "~17.0.6",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-video-thumbnails": "~9.0.3",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-incall-manager": "^4.2.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webrtc": "^124.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-incall-manager",
          "react-native-webrtc",
          "@config-plugins/react-native-webrtc",
          "expo-av"
        ]
      }
    }
  }
}
