# FUTUREHAT web — environment variables (Vite; only VITE_* are exposed to the app).
# Copy to `.env` and fill in real values. `.env` is gitignored.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Calls / WebRTC TURN — REQUIRED for production cross-network calling.
# Without TURN the app uses STUN only: calls connect on the same/permissive
# network but HANG on "Connecting…" across different networks/carriers/NATs.
# (There is no baked-in relay fallback — the old free OpenRelay one is dead.)
#
# Provision a TURN server (metered.ca has a free tier, or coturn / Twilio) and set
# the three vars below. VITE_TURN_URL accepts a COMMA-SEPARATED list so you can
# include every transport your provider gives you (udp/tcp/tls on 80/443) under
# the one username/credential — include a :443?transport=tcp or turns: entry so
# calls survive restrictive firewalls.
# VITE_TURN_URL=turn:turn.YOUR-DOMAIN.com:80,turn:turn.YOUR-DOMAIN.com:443?transport=tcp,turns:turn.YOUR-DOMAIN.com:443
# VITE_TURN_USERNAME=YOUR-TURN-USER
# VITE_TURN_CREDENTIAL=YOUR-TURN-SECRET
